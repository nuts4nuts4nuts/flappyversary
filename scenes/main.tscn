[sub_resource type="GDScript" id="GDScript_hbbrn"]
script/source = "extends Label

var tween
var is_dying = false

# Called when the node enters the scene tree for the first time.
func _ready():
	text = \"融
合
融
合
融
合
融
合
融
合
融
合
融
合\"
	GameEvents.target_ball_dying.connect(_on_target_dying)
	GameEvents.target_ball_safe.connect(_on_target_safe)


func _on_target_dying(_time_remaining: float):
	if !is_dying:
		is_dying = true
		activate()


func _on_target_safe():
	if is_dying:
		is_dying = false
		return_to_normal()


func activate():
	if(tween):
		tween.kill()
	tween = create_tween()
	tween.tween_interval(0.6)
	tween.tween_property(self, \"position:y\", -5355, 10).as_relative()


func scroll():
	tween.tween_property(self, \"position:y\", -5355, 10)


func return_to_normal():
	if(tween):
		tween.kill()
	tween = create_tween()
	tween.tween_property(self, \"position:y\", 5355, 10)


func _on_animation_player_text_animation_finished(anim_name):
	pass # Replace with function body.
"

